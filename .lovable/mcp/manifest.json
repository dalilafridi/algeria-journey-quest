{
  "version": 1,
  "sdk_version": "0.22.1",
  "path": "/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "algeria-through-time",
      "version": "0.1.0",
      "title": "Algeria Through Time"
    },
    "tools": [
      {
        "name": "list_figures",
        "title": "List historical figures",
        "description": "List Algerian historical figures in the museum. Optionally filter by category (e.g. ancient, roman, islamic, ottoman, colonial, revolutionary, modern, culture) or region.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "category": {
              "description": "Filter by figure category id.",
              "type": "string"
            },
            "region": {
              "description": "Filter by figure region id.",
              "type": "string"
            },
            "search": {
              "description": "Case-insensitive substring match on English display name.",
              "type": "string"
            },
            "limit": {
              "description": "Max results to return. Default 50.",
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            },
            "lang": {
              "description": "Language for localized fields. Defaults to 'en'.",
              "type": "string",
              "enum": [
                "en",
                "fr",
                "ar"
              ]
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_figure",
        "title": "Get figure exhibit",
        "description": "Return the full museum exhibit for one historical figure: story, importance, memorable fact, extended narrative, and era link.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "Figure id (e.g. 'dihya', 'ben-mhidi'). Use list_figures to discover ids."
            },
            "lang": {
              "type": "string",
              "enum": [
                "en",
                "fr",
                "ar"
              ]
            }
          },
          "required": [
            "id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_eras",
        "title": "List historical eras",
        "description": "List the historical eras covered by the museum (Numidian, Roman, Islamic, Ottoman, Colonial, Independence, Modern).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "lang": {
              "type": "string",
              "enum": [
                "en",
                "fr",
                "ar"
              ]
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_era",
        "title": "Get era exhibit",
        "description": "Return an era exhibit: overview, dates, and key content in the requested language.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "Era id. Use list_eras to discover ids."
            },
            "lang": {
              "type": "string",
              "enum": [
                "en",
                "fr",
                "ar"
              ]
            }
          },
          "required": [
            "id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_regions",
        "title": "List regions",
        "description": "List Algerian regions covered in the atlas (Kabylie, Aurès, Sahara, etc.).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "lang": {
              "type": "string",
              "enum": [
                "en",
                "fr",
                "ar"
              ]
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_region",
        "title": "Get region exhibit",
        "description": "Return the full region exhibit: identity, key historical facts, and connected figures.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "Region id (e.g. 'kabylie', 'aures', 'sahara'). Use list_regions to discover ids."
            },
            "lang": {
              "type": "string",
              "enum": [
                "en",
                "fr",
                "ar"
              ]
            }
          },
          "required": [
            "id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_culture_topics",
        "title": "List culture topics",
        "description": "List cultural exhibits (Music, Cuisine, Architecture, Languages, Literature, Festivals, Oral Traditions).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "lang": {
              "type": "string",
              "enum": [
                "en",
                "fr",
                "ar"
              ]
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_culture_topic",
        "title": "Get culture topic exhibit",
        "description": "Return full cultural topic content: significance, historical context, living traditions, and curator note.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "Culture topic id (e.g. 'music', 'cuisine'). Use list_culture_topics to discover ids."
            },
            "lang": {
              "type": "string",
              "enum": [
                "en",
                "fr",
                "ar"
              ]
            }
          },
          "required": [
            "id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_journeys",
        "title": "List signature journeys",
        "description": "List curated Signature Journeys through Algerian history (the Grand Tour and thematic paths).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "lang": {
              "type": "string",
              "enum": [
                "en",
                "fr",
                "ar"
              ]
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_journey",
        "title": "Get journey",
        "description": "Return the full journey with all stops, framings, and curator commentary.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "Journey id (e.g. 'grand-tour'). Use list_journeys to discover ids."
            },
            "lang": {
              "type": "string",
              "enum": [
                "en",
                "fr",
                "ar"
              ]
            }
          },
          "required": [
            "id"
          ]
        },
        "outputSchema": null
      }
    ]
  }
